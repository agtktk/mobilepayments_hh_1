---
import { siteConfig } from '../../site.config.js';

const ariaLabel = '\uc0c1\ub2f4 \ubc14\ub85c\uac00\uae30';
const buttons = [
  {
    label: '\uc804\ud654\uc0c1\ub2f4',
    icon: '\u260e',
    href: siteConfig.floatingButtons.phone,
    className: 'floating-contact-button phone'
  },
  {
    label: '\ubb38\uc790\uc0c1\ub2f4',
    icon: '\u2709',
    href: siteConfig.floatingButtons.sms,
    className: 'floating-contact-button sms'
  },
  {
    label: '\uce74\uce74\uc624\ud1a1 \uc0c1\ub2f4',
    icon: '\ud83d\udcac',
    href: siteConfig.floatingButtons.kakao,
    className: 'floating-contact-button kakao'
  }
];
---

<aside class="floating-contact" aria-label={ariaLabel}>
  {buttons.map((button) => (
    <a
      class={button.className}
      href={button.href}
      target={button.href.startsWith('http') ? '_blank' : undefined}
      rel={button.href.startsWith('http') ? 'noopener noreferrer' : undefined}
    >
      <span aria-hidden="true">{button.icon}</span>
      <span>{button.label}</span>
    </a>
  ))}
</aside>
